PORT=3000
MODE=DEV
URL=mongodb://127.0.0.1:27017/wadiny

SALT_ROUNDS=10
SECRET_KEY=your-aes-secret-key

# JWT — user role
PREFIX_TOKEN_USER=BearerUser
ACCESS_SIGNATURE_USER=access-user-secret
REFRESH_SIGNATURE_USER=refresh-user-secret

# JWT — admin role
PREFIX_TOKEN_ADMIN=BearerAdmin
ACCESS_SIGNATURE_ADMIN=access-admin-secret
REFRESH_SIGNATURE_ADMIN=refresh-admin-secret

# JWT — restaurant role
PREFIX_TOKEN_REST=BearerRest
ACCESS_SIGNATURE_REST=access-rest-secret
REFRESH_SIGNATURE_REST=refresh-rest-secret

email=your-smtp@gmail.com
password=your-app-password

CLIENT_ID=google-oauth-client-id
CLIENT_SECRET=google-oauth-client-secret

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GEMINI_API_KEY=
ORS_API_KEY=
